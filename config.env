# ─────────────────────────────────────────────
#  Ubuntu Update Notifier — Configuration File
# ─────────────────────────────────────────────

# ── Email Settings ───────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@gmail.com"
SMTP_PASS="your_app_password"       # Use an App Password, not your login password
NOTIFY_EMAIL="you@gmail.com"        # Where notifications are sent
FROM_NAME="Ubuntu Update Notifier"

# ── Server Settings ──────────────────────────
# The IP/hostname the user's email client can reach this machine on.
# Use your LAN IP (e.g. 192.168.1.100) or a domain if publicly reachable.
SERVER_HOST="192.168.1.100"
SERVER_PORT="8765"

# ── Update Settings ──────────────────────────
# How many days to wait before re-notifying after a "Later" response
POSTPONE_DAYS=1

# ── Paths (leave as-is unless you know what you're doing) ────────────────
STATE_DIR="/var/lib/update-notifier"
LOG_FILE="/var/log/update-notifier.log"
